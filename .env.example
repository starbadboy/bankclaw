# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── PDF Passwords (existing) ──────────────────────────────────────────────────
# JSON array of passwords to try when unlocking encrypted PDF statements.
# PDF_PASSWORDS='["password1", "password2"]'

# ── DeepSeek AI (for transaction categorisation) ──────────────────────────────
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── MongoDB Atlas (for storing categorised transactions) ──────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/

# Optional: override the default database name (default: bankclaw)
# MONGODB_DB_NAME=bankclaw
